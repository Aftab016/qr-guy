---
---
<header class="sticky top-0 z-40 w-full h-16 border-b border-hairline bg-canvas/80 backdrop-blur-md flex items-center justify-between px-6 md:px-8">
  <!-- Left: Logo -->
  <div class="flex items-center gap-3">
    <a href="/" class="flex items-center gap-2 group focus:outline-none" aria-label="QR Guy Home">
      <!-- Vercel-like Stylized Triangle/QR Logo -->
      <div class="relative w-6 h-6 flex items-center justify-center">
        <!-- Solid triangle -->
        <svg viewBox="0 0 100 100" class="w-5 h-5 fill-ink group-hover:opacity-80 transition-opacity">
          <polygon points="50,15 90,85 10,85"/>
        </svg>
      </div>
      <span class="font-sans font-semibold text-lg tracking-tight text-ink">QR Guy</span>
    </a>
    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-link-bg-soft dark:bg-link-deep/20 text-link dark:text-cyan text-[11px] font-mono font-medium">
      v1.0.0
    </span>
  </div>

  <!-- Center: Nav Tabs (Desktop) -->
  <nav class="hidden md:flex items-center gap-1" aria-label="Main Navigation">
    <button 
      data-tab-btn="generator" 
      class="nav-tab-btn px-4 py-1.5 text-sm font-medium rounded-pill text-ink bg-canvas-soft-2 border border-hairline transition-all cursor-pointer focus:outline-none"
    >
      Generator
    </button>
    <button 
      data-tab-btn="scanner" 
      class="nav-tab-btn px-4 py-1.5 text-sm font-medium rounded-pill text-body hover:text-ink transition-all cursor-pointer hover:bg-canvas-soft-2/50 focus:outline-none"
    >
      Scanner
    </button>
    <button 
      data-tab-btn="history" 
      class="nav-tab-btn px-4 py-1.5 text-sm font-medium rounded-pill text-body hover:text-ink transition-all cursor-pointer hover:bg-canvas-soft-2/50 focus:outline-none"
    >
      History
      <span id="history-badge" class="hidden ml-1 px-1.5 py-0.1 text-[10px] bg-hairline-strong text-canvas rounded-full">0</span>
    </button>
    <button 
      data-tab-btn="developer" 
      class="nav-tab-btn px-4 py-1.5 text-sm font-medium rounded-pill text-body hover:text-ink transition-all cursor-pointer hover:bg-canvas-soft-2/50 focus:outline-none"
    >
      Developer API
    </button>
  </nav>

  <!-- Right: Actions -->
  <div class="flex items-center gap-4">
    <!-- Theme Toggle Button -->
    <button 
      id="theme-toggle" 
      class="w-8 h-8 rounded-md flex items-center justify-center text-body hover:text-ink border border-hairline hover:bg-canvas-soft-2 transition-all cursor-pointer focus:outline-none"
      aria-label="Toggle dark mode"
    >
      <!-- Sun icon (shown in light mode) -->
      <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 hidden dark:block">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21M5.22 5.22l1.59 1.59m10.38 10.38l1.59 1.59M12 6.75a5.25 5.25 0 1 0 0 10.5 5.25 5.25 0 0 0 0-10.5ZM3 12h2.25m13.5 0H21M5.22 18.78l1.59-1.59m10.38-10.38l1.59-1.59" />
      </svg>
      <!-- Moon icon (shown in dark mode) -->
      <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 dark:hidden">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
      </svg>
    </button>

    <!-- GitHub Link -->
    <a 
      href="https://github.com/qrguy/qrguy.com" 
      target="_blank" 
      rel="noopener noreferrer" 
      class="w-8 h-8 rounded-md flex items-center justify-center text-body hover:text-ink border border-hairline hover:bg-canvas-soft-2 transition-all focus:outline-none"
      aria-label="GitHub Repository"
    >
      <svg class="w-4 h-4 fill-current" viewBox="0 0 16 16">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
      </svg>
    </a>

    <!-- CTA Button -->
    <button 
      data-action="start-generating" 
      class="hidden sm:inline-flex items-center justify-center px-4 py-1.5 text-xs font-semibold rounded-sm bg-primary text-on-primary hover:opacity-90 active:scale-98 transition-all cursor-pointer focus:outline-none"
    >
      Start Generating
    </button>
  </div>
</header>

<script>
  // Client-side theme toggling
  const themeToggle = document.getElementById('theme-toggle');
  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  }

  // Handle active navigation styling dynamically (SPA behavior)
  const tabButtons = document.querySelectorAll('.nav-tab-btn');
  
  // Set tab active function
  window.addEventListener('hashchange', updateActiveTab);
  
  function updateActiveTab() {
    const hash = window.location.hash.replace('#', '') || 'generator';
    
    tabButtons.forEach(btn => {
      const btnTab = btn.getAttribute('data-tab-btn');
      if (btnTab === hash) {
        btn.classList.add('bg-canvas-soft-2', 'border-hairline', 'text-ink');
        btn.classList.remove('text-body', 'hover:bg-canvas-soft-2/50');
      } else {
        btn.classList.remove('bg-canvas-soft-2', 'border-hairline', 'text-ink');
        btn.classList.add('text-body', 'hover:bg-canvas-soft-2/50');
      }
    });

    // Dispatch a custom event to change visibility of tab containers
    const tabChangeEvent = new CustomEvent('tab-change', { detail: { tab: hash } });
    window.dispatchEvent(tabChangeEvent);
  }

  // Bind tab click handlers
  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.getAttribute('data-tab-btn');
      window.location.hash = `#${tab}`;
    });
  });

  // Start Generating button handler
  const startBtn = document.querySelector('[data-action="start-generating"]');
  if (startBtn) {
    startBtn.addEventListener('click', () => {
      window.location.hash = '#generator';
    });
  }

  // Initialize on first load
  updateActiveTab();
</script>
