---
interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "QR Guy — Create Premium Styled QR Codes", 
	description = "Create highly customizable, premium QR codes with custom shapes, linear/radial gradients, custom logos, and presets. 100% client-side, free, and private." 
} = Astro.props;

import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href="https://qrguy.com" />
		
		<!-- Favicon -->
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="Qr Guy" />
		<link rel="manifest" href="/site.webmanifest" />
		
		<!-- Typography: Geist & Geist Mono from Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />

		<!-- Inline Theme Synchronization Script (Prevents flash) -->
		<script is:inline>
			const getThemePreference = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			};
			
			const isDark = getThemePreference() === 'dark';
			document.documentElement.classList.toggle('dark', isDark);
		</script>
	</head>
	<body class="bg-canvas-soft text-ink min-h-screen flex flex-col selection:bg-primary selection:text-on-primary">
		<slot />
	</body>
</html>
