---
---
<div id="tab-generator" class="w-full max-w-[1400px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 py-8 px-6 md:px-8 font-sans">
  <!-- Left Side: Customization & Inputs (7 Columns) -->
  <div class="lg:col-span-7 flex flex-col gap-6">
    <!-- Section 1: Method Picker -->
    <div class="bg-canvas border border-hairline rounded-lg shadow-level-2 p-6">
      <h2 class="text-xs font-mono font-medium text-mute uppercase tracking-wider mb-4">Method 1, 2, or 3 — Select Source</h2>
      
      <!-- Source Tabs -->
      <div class="flex border-b border-hairline mb-6 gap-2" role="tablist">
        <button 
          id="btn-method-url"
          class="method-tab-btn border-b-2 border-primary text-ink px-4 py-2 text-sm font-medium focus:outline-none cursor-pointer"
          role="tab"
          aria-selected="true"
        >
          Link to QR
        </button>
        <button 
          id="btn-method-phone"
          class="method-tab-btn border-b-2 border-transparent text-body hover:text-ink px-4 py-2 text-sm font-medium focus:outline-none cursor-pointer"
          role="tab"
          aria-selected="false"
        >
          Number to QR
        </button>
        <button 
          id="btn-method-code"
          class="method-tab-btn border-b-2 border-transparent text-body hover:text-ink px-4 py-2 text-sm font-medium focus:outline-none cursor-pointer"
          role="tab"
          aria-selected="false"
        >
          Code / Text to QR
        </button>
      </div>

      <!-- Content 1: Link -->
      <div id="method-url-pane" class="method-pane block">
        <div class="flex flex-col gap-2">
          <label for="input-url" class="text-xs font-semibold text-ink">Target Link (URL)</label>
          <input 
            type="url" 
            id="input-url" 
            placeholder="examples.com" 
            class="w-full px-4 h-10 border border-hairline rounded-sm bg-canvas text-ink text-sm focus:outline-none focus:ring-1 focus:ring-primary"
          />
          <p class="text-[11px] text-mute font-mono">Real-time URL validation enabled. Automatically adds https:// if missing.</p>
        </div>
      </div>

      <!-- Content 2: Phone Number -->
      <div id="method-phone-pane" class="method-pane hidden">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="flex flex-col gap-2">
            <label for="input-phone" class="text-xs font-semibold text-ink">Phone Number</label>
            <input 
              type="tel" 
              id="input-phone" 
              placeholder="+1 (555) 000-0000" 
              class="w-full px-4 h-10 border border-hairline rounded-sm bg-canvas text-ink text-sm focus:outline-none focus:ring-1 focus:ring-primary"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label for="input-phone-action" class="text-xs font-semibold text-ink">Action Type</label>
            <select 
              id="input-phone-action"
              class="w-full px-3 h-10 border border-hairline rounded-sm bg-canvas text-ink text-sm focus:outline-none focus:ring-1 focus:ring-primary"
            >
              <option value="tel">Direct Call (tel:)</option>
              <option value="sms">SMS Text (SMSTO:)</option>
            </select>
          </div>
          <div id="sms-body-container" class="col-span-1 md:col-span-2 flex flex-col gap-2 hidden">
            <label for="input-sms-body" class="text-xs font-semibold text-ink">SMS Prefilled Message (Optional)</label>
            <textarea 
              id="input-sms-body" 
              rows="2"
              placeholder="Enter text message to prefill..." 
              class="w-full p-3 border border-hairline rounded-sm bg-canvas text-ink text-sm focus:outline-none focus:ring-1 focus:ring-primary resize-none"
            ></textarea>
          </div>
        </div>
      </div>

      <!-- Content 3: Code / Custom Text -->
      <div id="method-code-pane" class="method-pane hidden">
        <div class="flex flex-col gap-4">
          <!-- Templates selector inside Code Tab -->
          <div class="flex flex-wrap gap-2 items-center">
            <span class="text-xs font-medium text-mute mr-1">Templates:</span>
            <button id="tpl-raw" class="px-2.5 py-1 text-xs rounded-sm border border-primary bg-primary text-on-primary font-medium focus:outline-none cursor-pointer">Raw Text</button>
            <button id="tpl-wifi" class="px-2.5 py-1 text-xs rounded-sm border border-hairline hover:bg-canvas-soft-2 text-body hover:text-ink font-medium focus:outline-none cursor-pointer">Wi-Fi Network</button>
            <button id="tpl-vcard" class="px-2.5 py-1 text-xs rounded-sm border border-hairline hover:bg-canvas-soft-2 text-body hover:text-ink font-medium focus:outline-none cursor-pointer">VCard / Contact</button>
          </div>

          <!-- Wi-Fi Helper Panel -->
          <div id="helper-wifi-panel" class="hidden grid grid-cols-1 md:grid-cols-3 gap-3 p-4 bg-canvas-soft-2 border border-hairline rounded-md">
            <div class="flex flex-col gap-1.5">
              <label for="wifi-ssid" class="text-xs font-medium text-body">SSID (Network Name)</label>
              <input type="text" id="wifi-ssid" placeholder="HomeNet" class="px-3 h-8 border border-hairline rounded-sm bg-canvas text-ink text-xs focus:outline-none"/>
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="wifi-pass" class="text-xs font-medium text-body">Password</label>
              <input type="password" id="wifi-pass" placeholder="••••••••" class="px-3 h-8 border border-hairline rounded-sm bg-canvas text-ink text-xs focus:outline-none"/>
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="wifi-type" class="text-xs font-medium text-body">Security</label>
              <select id="wifi-type" class="px-2 h-8 border border-hairline rounded-sm bg-canvas text-ink text-xs focus:outline-none">
                <option value="WPA">WPA/WPA2</option>
                <option value="WEP">WEP</option>
                <option value="nopass">Unsecured</option>
              </select>
            </div>
          </div>

          <!-- VCard Helper Panel -->
          <div id="helper-vcard-panel" class="hidden grid grid-cols-1 md:grid-cols-2 gap-3 p-4 bg-canvas-soft-2 border border-hairline rounded-md">
            <div class="flex flex-col gap-1.5">
              <label for="vcard-name" class="text-xs font-medium text-body">Full Name</label>
              <input type="text" id="vcard-name" placeholder="John Doe" class="px-3 h-8 border border-hairline rounded-sm bg-canvas text-ink text-xs focus:outline-none"/>
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="vcard-phone" class="text-xs font-medium text-body">Phone</label>
              <input type="text" id="vcard-phone" placeholder="+1 555 1234" class="px-3 h-8 border border-hairline rounded-sm bg-canvas text-ink text-xs focus:outline-none"/>
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="vcard-email" class="text-xs font-medium text-body">Email</label>
              <input type="email" id="vcard-email" placeholder="john@example.com" class="px-3 h-8 border border-hairline rounded-sm bg-canvas text-ink text-xs focus:outline-none"/>
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="vcard-org" class="text-xs font-medium text-body">Company / Org</label>
              <input type="text" id="vcard-org" placeholder="Acme Inc." class="px-3 h-8 border border-hairline rounded-sm bg-canvas text-ink text-xs focus:outline-none"/>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="input-code" class="text-xs font-semibold text-ink">Code / Text Content</label>
            <textarea 
              id="input-code" 
              rows="4" 
              placeholder="Enter text, code, JSON, or select a template..."
              class="w-full p-3 border border-hairline rounded-sm bg-canvas text-ink text-sm font-mono focus:outline-none focus:ring-1 focus:ring-primary"
            ></textarea>
            <p class="text-[11px] text-mute font-mono">Format outputs dynamically. Changes to fields above compile here automatically.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Section 2: Customization Options Accordion -->
    <div class="flex flex-col border border-hairline rounded-lg bg-canvas shadow-level-2 divide-y divide-hairline">
      
      <!-- Accordion Header: Presets -->
      <details class="group/acc" open>
        <summary class="flex items-center justify-between p-5 font-semibold text-sm text-ink cursor-pointer list-none select-none focus:outline-none">
          <span>1. Design Presets (Instant Styles)</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-mute group-open/acc:rotate-180 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>
        <div class="p-5 pt-0 border-t border-hairline/30">
          <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
            <button 
              data-preset="stark" 
              class="preset-btn p-3 rounded-md border border-primary text-ink text-center flex flex-col items-center gap-1.5 hover:bg-canvas-soft-2 transition-all cursor-pointer focus:outline-none"
            >
              <div class="w-6 h-6 rounded-full bg-ink flex items-center justify-center text-canvas font-mono text-[11px] font-bold">Q</div>
              <span class="text-[11px] font-medium font-sans">Stark Mono</span>
            </button>
            <button 
              data-preset="cyber" 
              class="preset-btn p-3 rounded-md border border-hairline text-body hover:text-ink text-center flex flex-col items-center gap-1.5 hover:bg-canvas-soft-2 transition-all cursor-pointer focus:outline-none"
            >
              <div class="w-6 h-6 rounded-full bg-gradient-to-r from-violet to-highlight-pink flex items-center justify-center font-mono text-[10px]"></div>
              <span class="text-[11px] font-medium font-sans">Midnight Cyber</span>
            </button>
            <button 
              data-preset="mint" 
              class="preset-btn p-3 rounded-md border border-hairline text-body hover:text-ink text-center flex flex-col items-center gap-1.5 hover:bg-canvas-soft-2 transition-all cursor-pointer focus:outline-none"
            >
              <div class="w-6 h-6 rounded-full bg-gradient-to-r from-link to-cyan flex items-center justify-center font-mono text-[10px]"></div>
              <span class="text-[11px] font-medium font-sans">Neo Mint</span>
            </button>
            <button 
              data-preset="sunset" 
              class="preset-btn p-3 rounded-md border border-hairline text-body hover:text-ink text-center flex flex-col items-center gap-1.5 hover:bg-canvas-soft-2 transition-all cursor-pointer focus:outline-none"
            >
              <div class="w-6 h-6 rounded-full bg-gradient-to-r from-gradient-ship-start to-gradient-ship-end flex items-center justify-center font-mono text-[10px]"></div>
              <span class="text-[11px] font-medium font-sans">Sunset Rose</span>
            </button>
            <button 
              data-preset="classic" 
              class="preset-btn p-3 rounded-md border border-hairline text-body hover:text-ink text-center flex flex-col items-center gap-1.5 hover:bg-canvas-soft-2 transition-all cursor-pointer focus:outline-none"
            >
              <div class="w-6 h-6 rounded-sm bg-black border border-white flex items-center justify-center text-white font-mono text-[8px]">QR</div>
              <span class="text-[11px] font-medium font-sans">Classic Mono</span>
            </button>
          </div>
        </div>
      </details>

      <!-- Accordion Header: Colors -->
      <details class="group/acc">
        <summary class="flex items-center justify-between p-5 font-semibold text-sm text-ink cursor-pointer list-none select-none focus:outline-none">
          <span>2. Color Palette & Gradients</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-mute group-open/acc:rotate-180 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>
        <div class="p-5 pt-0 border-t border-hairline/30 flex flex-col gap-5">
          <!-- Foreground Type -->
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-2">
              <label class="text-xs font-semibold text-ink">Foreground Style</label>
              <div class="flex p-0.5 bg-canvas-soft-2 border border-hairline rounded-sm">
                <button id="btn-fg-solid" class="flex-1 text-center py-1 text-xs font-medium bg-canvas border border-hairline text-ink rounded-sm focus:outline-none cursor-pointer">Solid Color</button>
                <button id="btn-fg-gradient" class="flex-1 text-center py-1 text-xs font-medium text-body hover:text-ink rounded-sm focus:outline-none cursor-pointer">Gradient</button>
              </div>
            </div>
            
            <!-- Solid Color Picker -->
            <div id="fg-solid-container" class="flex flex-col gap-2">
              <label for="color-fg" class="text-xs font-semibold text-ink">Solid Color</label>
              <div class="flex items-center gap-2">
                <input type="color" id="color-fg" value="#171717" class="w-10 h-8 border border-hairline rounded-sm cursor-pointer p-0 bg-transparent"/>
                <input type="text" id="color-fg-text" value="#171717" class="flex-1 px-3 h-8 border border-hairline rounded-sm bg-canvas text-ink text-xs focus:outline-none uppercase font-mono"/>
              </div>
            </div>
          </div>

          <!-- Gradient Configurations -->
          <div id="fg-gradient-container" class="hidden grid grid-cols-1 md:grid-cols-4 gap-4 p-4 bg-canvas-soft-2 border border-hairline rounded-md">
            <div class="flex flex-col gap-1.5">
              <label for="color-grad-start" class="text-[11px] font-semibold text-body">Start Color</label>
              <div class="flex items-center gap-1">
                <input type="color" id="color-grad-start" value="#007cf0" class="w-8 h-8 border border-hairline rounded-sm cursor-pointer p-0 bg-transparent"/>
                <input type="text" id="color-grad-start-text" value="#007cf0" class="w-16 px-1 h-8 border border-hairline rounded-sm bg-canvas text-ink text-[10px] focus:outline-none uppercase font-mono"/>
              </div>
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="color-grad-end" class="text-[11px] font-semibold text-body">End Color</label>
              <div class="flex items-center gap-1">
                <input type="color" id="color-grad-end" value="#00dfd8" class="w-8 h-8 border border-hairline rounded-sm cursor-pointer p-0 bg-transparent"/>
                <input type="text" id="color-grad-end-text" value="#00dfd8" class="w-16 px-1 h-8 border border-hairline rounded-sm bg-canvas text-ink text-[10px] focus:outline-none uppercase font-mono"/>
              </div>
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="grad-type" class="text-[11px] font-semibold text-body">Type</label>
              <select id="grad-type" class="w-full h-8 border border-hairline rounded-sm bg-canvas text-ink text-xs focus:outline-none px-1">
                <option value="linear">Linear</option>
                <option value="radial">Radial</option>
              </select>
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="grad-angle" class="text-[11px] font-semibold text-body">Angle (deg)</label>
              <input type="number" id="grad-angle" value="45" min="0" max="360" class="w-full h-8 border border-hairline rounded-sm bg-canvas text-ink text-xs focus:outline-none px-2 font-mono"/>
            </div>
          </div>

          <!-- Background Settings -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="flex flex-col gap-2">
              <label for="color-bg" class="text-xs font-semibold text-ink">Background Color</label>
              <div class="flex items-center gap-2">
                <input type="color" id="color-bg" value="#ffffff" class="w-10 h-8 border border-hairline rounded-sm cursor-pointer p-0 bg-transparent"/>
                <input type="text" id="color-bg-text" value="#ffffff" class="flex-1 px-3 h-8 border border-hairline rounded-sm bg-canvas text-ink text-xs focus:outline-none uppercase font-mono"/>
              </div>
            </div>
            <div class="flex items-center gap-2 pt-6">
              <input type="checkbox" id="bg-transparent" class="w-4 h-4 border border-hairline rounded-sm bg-canvas text-ink accent-primary cursor-pointer"/>
              <label for="bg-transparent" class="text-xs font-semibold text-ink cursor-pointer">Transparent Background</label>
            </div>
          </div>

          <!-- Custom Eye Colors -->
          <div class="border-t border-hairline pt-4">
            <div class="flex items-center gap-2 mb-3">
              <input type="checkbox" id="eye-color-override" class="w-4 h-4 border border-hairline rounded-sm bg-canvas text-ink accent-primary cursor-pointer"/>
              <label for="eye-color-override" class="text-xs font-semibold text-ink cursor-pointer">Customize Corners (Eyes) Colors</label>
            </div>
            <div id="eye-colors-container" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4 p-4 bg-canvas-soft-2 border border-hairline rounded-md">
              <div class="flex flex-col gap-2">
                <label for="color-eye-frame" class="text-xs font-semibold text-ink">Eye Frame (Outer Square)</label>
                <div class="flex items-center gap-2">
                  <input type="color" id="color-eye-frame" value="#171717" class="w-8 h-8 border border-hairline rounded-sm cursor-pointer p-0 bg-transparent"/>
                  <input type="text" id="color-eye-frame-text" value="#171717" class="flex-1 px-3 h-8 border border-hairline rounded-sm bg-canvas text-ink text-xs focus:outline-none uppercase font-mono"/>
                </div>
              </div>
              <div class="flex flex-col gap-2">
                <label for="color-eye-ball" class="text-xs font-semibold text-ink">Eye Ball (Inner Dot)</label>
                <div class="flex items-center gap-2">
                  <input type="color" id="color-eye-ball" value="#171717" class="w-8 h-8 border border-hairline rounded-sm cursor-pointer p-0 bg-transparent"/>
                  <input type="text" id="color-eye-ball-text" value="#171717" class="flex-1 px-3 h-8 border border-hairline rounded-sm bg-canvas text-ink text-xs focus:outline-none uppercase font-mono"/>
                </div>
              </div>
            </div>
          </div>
        </div>
      </details>

      <!-- Accordion Header: Shapes -->
      <details class="group/acc">
        <summary class="flex items-center justify-between p-5 font-semibold text-sm text-ink cursor-pointer list-none select-none focus:outline-none">
          <span>3. Shapes & Custom Geometry</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-mute group-open/acc:rotate-180 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>
        <div class="p-5 pt-0 border-t border-hairline/30 grid grid-cols-1 sm:grid-cols-3 gap-4">
          <!-- Dots shape -->
          <div class="flex flex-col gap-2">
            <label for="shape-dots" class="text-xs font-semibold text-ink">QR Body Dots</label>
            <select id="shape-dots" class="w-full h-10 border border-hairline rounded-sm bg-canvas text-ink text-sm focus:outline-none px-2">
              <option value="square">Square (Default)</option>
              <option value="dots">Circular Dots</option>
              <option value="rounded">Rounded Blocks</option>
              <option value="extra-rounded">Extra Rounded</option>
              <option value="classy">Classy Style</option>
              <option value="classy-rounded">Classy Rounded</option>
            </select>
          </div>

          <!-- Eye Frame shape -->
          <div class="flex flex-col gap-2">
            <label for="shape-eye-frame" class="text-xs font-semibold text-ink">Corner Frame (Outer)</label>
            <select id="shape-eye-frame" class="w-full h-10 border border-hairline rounded-sm bg-canvas text-ink text-sm focus:outline-none px-2">
              <option value="square">Square (Default)</option>
              <option value="dot">Circle / Dot</option>
              <option value="rounded">Rounded</option>
              <option value="extra-rounded">Extra Rounded</option>
            </select>
          </div>

          <!-- Eye Ball shape -->
          <div class="flex flex-col gap-2">
            <label for="shape-eye-ball" class="text-xs font-semibold text-ink">Corner Ball (Inner)</label>
            <select id="shape-eye-ball" class="w-full h-10 border border-hairline rounded-sm bg-canvas text-ink text-sm focus:outline-none px-2">
              <option value="square">Square (Default)</option>
              <option value="dot">Circle / Dot</option>
              <option value="rounded">Rounded</option>
              <option value="extra-rounded">Extra Rounded</option>
            </select>
          </div>
        </div>
      </details>

      <!-- Accordion Header: Logo -->
      <details class="group/acc">
        <summary class="flex items-center justify-between p-5 font-semibold text-sm text-ink cursor-pointer list-none select-none focus:outline-none">
          <span>4. Logo Overlay (Branding)</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-mute group-open/acc:rotate-180 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>
        <div class="p-5 pt-0 border-t border-hairline/30 flex flex-col gap-4">
          <!-- Preset Icons vs Upload -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- File upload -->
            <div class="flex flex-col gap-2">
              <label class="text-xs font-semibold text-ink">Upload Custom Logo</label>
              <input 
                type="file" 
                id="logo-upload" 
                accept="image/*"
                class="block w-full text-xs text-mute file:mr-4 file:py-1.5 file:px-4 file:rounded-sm file:border file:border-hairline file:text-xs file:font-semibold file:bg-canvas file:text-ink file:cursor-pointer hover:file:bg-canvas-soft-2"
              />
            </div>
            
            <!-- Preset Icons -->
            <div class="flex flex-col gap-2">
              <label for="logo-preset" class="text-xs font-semibold text-ink">Or Choose Preset Icon</label>
              <select id="logo-preset" class="w-full h-10 border border-hairline rounded-sm bg-canvas text-ink text-sm focus:outline-none px-2">
                <option value="none">No Icon (None)</option>
                <option value="link">Link Icon</option>
                <option value="phone">Phone Icon</option>
                <option value="github">GitHub Octocat</option>
                <option value="star">Star Badge</option>
                <option value="qrcode">QR Icon</option>
              </select>
            </div>
          </div>

          <!-- Logo Styling sliders (Shown only if logo selected) -->
          <div id="logo-settings-panel" class="hidden grid grid-cols-1 md:grid-cols-3 gap-4 p-4 bg-canvas-soft-2 border border-hairline rounded-md">
            <div class="flex flex-col gap-1.5">
              <label for="logo-size" class="text-xs font-semibold text-ink">Logo Size (Ratio)</label>
              <div class="flex items-center gap-2">
                <input type="range" id="logo-size" min="0.05" max="0.4" step="0.05" value="0.15" class="flex-1 accent-primary"/>
                <span id="lbl-logo-size" class="text-xs font-mono w-8 text-right">15%</span>
              </div>
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="logo-margin" class="text-xs font-semibold text-ink">Logo Margin (px)</label>
              <div class="flex items-center gap-2">
                <input type="range" id="logo-margin" min="0" max="20" step="1" value="4" class="flex-1 accent-primary"/>
                <span id="lbl-logo-margin" class="text-xs font-mono w-8 text-right">4px</span>
              </div>
            </div>
            <div class="flex items-center gap-2 pt-4">
              <input type="checkbox" id="logo-bg-clean" checked class="w-4 h-4 border border-hairline rounded-sm bg-canvas text-ink accent-primary cursor-pointer"/>
              <label for="logo-bg-clean" class="text-xs font-semibold text-ink cursor-pointer">Clear background behind logo</label>
            </div>
          </div>
